# Optional. You can also configure these values in the web UI.
PORT=3000

# Active driver profile: odbc | jdbc
GAUSSDB_DRIVER_PROFILE=odbc

# Local GaussDB driver source paths. Fill the ones you need.
GAUSSDB_ODBC_PATH=D:/GaussDB/openGauss-connector-odbc
GAUSSDB_JDBC_PATH=D:/GaussDB/openGauss-connector-jdbc

# Recommended for the intranet MiniMax-M2.7 gateway if it is Anthropic-compatible.
AI_PROVIDER=anthropic
ANTHROPIC_AUTH_TOKEN=sk-REPLACE_ME
ANTHROPIC_BASE_URL=http://your-intranet-ai-gateway:8888/
ANTHROPIC_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_HAIKU_MODEL=MiniMax-M2.7
ANTHROPIC_DEFAULT_SONNET_MODEL=MiniMax-M2.7

# Optional. Raises GitHub API rate limit.
GITHUB_TOKEN=ghp_REPLACE_ME
# Also supported: GH_TOKEN or GITHUB_AUTH_TOKEN.

# Optional. Leave blank for direct intranet access.
HTTP_PROXY=
HTTPS_PROXY=

# Optional. Number of closed upstream PR pages to fetch, 100 PRs per page.
GITHUB_PR_PAGES=3

# Optional. Keep 1 for lite/limited AI gateways to avoid 429 concurrency errors.
AI_MAX_CONCURRENCY=1
AI_RETRY_ATTEMPTS=3
